# Copy to .env and edit. Used by docker-compose.yml (build) and
# docker-compose.ghcr.yml (prebuilt GHCR images).

# Database / MinIO credentials (change for anything beyond local dev)
POSTGRES_USER=giti
POSTGRES_PASSWORD=giti-dev-password
POSTGRES_DB=giti
MINIO_ROOT_USER=giti
MINIO_ROOT_PASSWORD=giti-dev-password

# Auth signing secret — CHANGE THIS in production
GITI_JWT_SECRET=giti-dev-secret

# GHCR images (docker-compose.ghcr.yml)
GHCR_OWNER=itsmadson
GITI_TAG=latest

# Go module proxy for building from source (docker-compose.yml)
GOPROXY=https://proxy.golang.org,direct
